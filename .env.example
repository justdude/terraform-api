# ============================================================================
# Environment variables for docker-compose and deploy.sh
# Copy this file to .env and fill in your values.
# ============================================================================

# --- Docker Compose runtime ---
APP_PORT=8080
ASPNETCORE_ENVIRONMENT=Production

# --- SSH Deployment (used by deploy/deploy.sh) ---
REMOTE_HOST=your-server-ip-or-hostname
REMOTE_USER=deploy
REMOTE_PORT=22
REMOTE_DIR=/opt/terraform-api
# SSH_KEY=~/.ssh/id_rsa   # optional — omit to use ssh-agent

# --- Docker image ---
IMAGE_NAME=terraform-api
IMAGE_TAG=latest

# --- CORS (set in appsettings or as env overrides) ---
# AllowedCorsOrigins__0=https://your-frontend.com
# AllowedCorsOrigins__1=https://admin.your-frontend.com
